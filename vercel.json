{
    "services": {
        "frontend": {
            "root": "frontend",
            "framework": "nextjs"
        },
        "backend": {
            "root": "backend",
            "framework": "express",
            "entrypoint": "src/server.ts"
        }
    },
    "rewrites": [
        {
            "source": "/api/(.*)",
            "destination": { "service": "backend" }
        },
        {
            "source": "/(.*)",
            "destination": { "service": "frontend" }
        }
    ]
}